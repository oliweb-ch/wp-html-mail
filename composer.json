{
    "name": "oliweb-ch/wp-html-mail",
    "description": "WP HTML Mail - Email Template Designer (oliweb-ch fork)",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Hannes Etzelstorfer // codemiq",
            "homepage": "https://codemiq.com",
            "role": "Original author"
        },
        {
            "name": "oliweb-ch",
            "homepage": "https://github.com/oliweb-ch",
            "role": "Fork maintainer"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "sabberworm/php-css-parser": "^8.7",
        "tijsverkoyen/css-to-inline-styles": "^2.4",
        "yahnis-elsts/plugin-update-checker": "^5.6"
    },
    "config": {
        "vendor-dir": "vendor",
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.4.99"
        }
    }
}
